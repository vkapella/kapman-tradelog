generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Broker {
  SCHWAB_THINKORSWIM
  FIDELITY
}

enum ImportStatus {
  UPLOADED
  PARSED
  COMMITTED
  FAILED
}

enum AssetClass {
  EQUITY
  OPTION
  CASH
  OTHER
}

enum EventType {
  TRADE
  EXPIRATION_INFERRED
  ASSIGNMENT
  EXERCISE
}

enum Side {
  BUY
  SELL
}

enum OpeningClosingEffect {
  TO_OPEN
  TO_CLOSE
  UNKNOWN
}

enum AdjustmentType {
  SPLIT
  QTY_OVERRIDE
  PRICE_OVERRIDE
  ADD_POSITION
  REMOVE_POSITION
  EXECUTION_QTY_OVERRIDE
  EXECUTION_PRICE_OVERRIDE
}

enum AdjustmentStatus {
  ACTIVE
  REVERSED
}

enum PositionSnapshotStatus {
  PENDING
  COMPLETE
  FAILED
}

enum MarkAssetClass {
  EQUITY
  OPTION
}

enum MarkSource {
  MASSIVE_S3
  POLYGON_REST
  MANUAL
}

enum ValueSnapshotSource {
  RECONSTRUCTED
  BROKER_NLV
  MIXED
}

model Account {
  id              String   @id @default(cuid())
  accountId       String   @unique @map("account_id")
  label           String
  displayLabel    String?  @map("display_label")
  broker          Broker
  brokerName      String?  @map("broker_name")
  paperMoney      Boolean  @default(false) @map("paper_money")
  startingCapital Decimal? @map("starting_capital") @db.Decimal(20, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  imports        Import[]
  executions     Execution[]
  snapshots      DailyAccountSnapshot[]
  cashEvents     CashEvent[]
  adjustments    ManualAdjustment[]
  setupGroups    SetupGroup[]
  matchedLots    MatchedLot[]
  valueSnapshots AccountValueSnapshot[]

  @@map("accounts")
}

model Import {
  id                   String       @id @default(cuid())
  filename             String
  broker               Broker
  status               ImportStatus
  parsedRows           Int          @default(0) @map("parsed_rows")
  persistedRows        Int          @default(0) @map("persisted_rows")
  skippedRows          Int          @default(0) @map("skipped_rows")
  skippedDuplicateRows Int          @default(0) @map("skipped_duplicate_rows")
  failedRows           Int          @default(0) @map("failed_rows")
  sourceFileText       String?      @map("source_file_text")
  warnings             Json?
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  executions       Execution[]
  importExecutions ImportExecution[]

  @@index([accountId])
  @@map("imports")
}

model Execution {
  id                   String                @id @default(cuid())
  broker               Broker
  eventTimestamp       DateTime              @map("event_timestamp")
  tradeDate            DateTime              @map("trade_date")
  eventType            EventType             @default(TRADE) @map("event_type")
  assetClass           AssetClass            @map("asset_class")
  symbol               String
  brokerTxId           String                @map("broker_tx_id")
  instrumentKey        String?               @map("instrument_key")
  descriptionRaw       String?               @map("description_raw")
  side                 Side?
  quantity             Decimal               @db.Decimal(20, 6)
  price                Decimal?              @db.Decimal(20, 6)
  grossAmount          Decimal?              @map("gross_amount") @db.Decimal(20, 6)
  fees                 Decimal?              @db.Decimal(20, 6)
  netAmount            Decimal?              @map("net_amount") @db.Decimal(20, 6)
  openingClosingEffect OpeningClosingEffect? @map("opening_closing_effect")
  underlyingSymbol     String?               @map("underlying_symbol")
  optionType           String?               @map("option_type")
  strike               Decimal?              @db.Decimal(20, 6)
  expirationDate       DateTime?             @map("expiration_date")
  multiplier           Int?
  spreadGroupId        String?               @map("spread_group_id")
  sourceRowRef         String?               @map("source_row_ref")
  rawRowJson           Json?                 @map("raw_row_json")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  importId String @map("import_id")
  import   Import @relation(fields: [importId], references: [id], onDelete: Cascade)

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  openMatchedLots  MatchedLot[]      @relation("open_execution")
  closeMatchedLots MatchedLot[]      @relation("close_execution")
  importLinks      ImportExecution[]

  @@unique([accountId, brokerTxId])
  @@index([accountId])
  @@index([importId])
  @@index([symbol])
  @@map("executions")
}

model ImportExecution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  importId String @map("import_id")
  import   Import @relation(fields: [importId], references: [id], onDelete: Cascade)

  executionId String    @map("execution_id")
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@unique([importId, executionId])
  @@index([executionId])
  @@map("import_executions")
}

model MatchedLot {
  id          String   @id @default(cuid())
  quantity    Decimal  @db.Decimal(20, 6)
  realizedPnl Decimal  @map("realized_pnl") @db.Decimal(20, 6)
  holdingDays Int      @map("holding_days")
  outcome     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  openExecutionId String    @map("open_execution_id")
  openExecution   Execution @relation("open_execution", fields: [openExecutionId], references: [id], onDelete: Cascade)

  closeExecutionId String?    @map("close_execution_id")
  closeExecution   Execution? @relation("close_execution", fields: [closeExecutionId], references: [id], onDelete: SetNull)

  setupGroupLots SetupGroupLot[]
  excursion      LotExcursion?

  @@index([accountId])
  @@map("matched_lots")
}

model SetupGroup {
  id               String   @id @default(cuid())
  tag              String
  overrideTag      String?  @map("override_tag")
  underlyingSymbol String   @map("underlying_symbol")
  realizedPnl      Decimal? @map("realized_pnl") @db.Decimal(20, 6)
  winRate          Decimal? @map("win_rate") @db.Decimal(8, 4)
  expectancy       Decimal? @db.Decimal(20, 6)
  averageHoldDays  Decimal? @map("average_hold_days") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  lots SetupGroupLot[]

  @@index([accountId])
  @@map("setup_groups")
}

model SetupGroupLot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  setupGroupId String     @map("setup_group_id")
  setupGroup   SetupGroup @relation(fields: [setupGroupId], references: [id], onDelete: Cascade)

  matchedLotId String     @map("matched_lot_id")
  matchedLot   MatchedLot @relation(fields: [matchedLotId], references: [id], onDelete: Cascade)

  @@unique([setupGroupId, matchedLotId])
  @@map("setup_group_lots")
}

model DailyAccountSnapshot {
  id                        String   @id @default(cuid())
  snapshotDate              DateTime @map("snapshot_date")
  balance                   Decimal  @db.Decimal(20, 6)
  totalCash                 Decimal? @map("total_cash") @db.Decimal(20, 6)
  brokerNetLiquidationValue Decimal? @map("broker_net_liquidation_value") @db.Decimal(20, 6)
  sourceRef                 String?  @map("source_ref")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, snapshotDate])
  @@index([snapshotDate])
  @@map("daily_account_snapshots")
}

model PositionSnapshot {
  id                String                 @id @default(cuid())
  accountIds        String                 @map("account_ids")
  snapshotAt        DateTime               @default(now()) @map("snapshot_at")
  status            PositionSnapshotStatus @default(PENDING)
  errorMessage      String?                @map("error_message")
  positionsJson     String                 @map("positions_json")
  accountValuesJson String                 @default("[]") @map("account_values_json")
  unrealizedPnl     Decimal?               @map("unrealized_pnl") @db.Decimal(20, 6)
  realizedPnl       Decimal?               @map("realized_pnl") @db.Decimal(20, 6)
  cashAdjustments   Decimal?               @map("cash_adjustments") @db.Decimal(20, 6)
  manualAdjustments Decimal?               @map("manual_adjustments") @db.Decimal(20, 6)
  currentNlv        Decimal?               @map("current_nlv") @db.Decimal(20, 6)
  startingCapital   Decimal?               @map("starting_capital") @db.Decimal(20, 6)
  totalGain         Decimal?               @map("total_gain") @db.Decimal(20, 6)
  unexplainedDelta  Decimal?               @map("unexplained_delta") @db.Decimal(20, 6)
  createdAt         DateTime               @default(now()) @map("created_at")

  @@index([snapshotAt(sort: Desc)])
  @@map("position_snapshots")
}

model CashEvent {
  id          String   @id @default(cuid())
  eventDate   DateTime @map("event_date")
  rowType     String   @map("row_type")
  refNumber   String   @map("ref_number")
  description String
  amount      Decimal  @db.Decimal(20, 6)
  sourceRef   String?  @map("source_ref")
  createdAt   DateTime @default(now()) @map("created_at")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, refNumber])
  @@index([accountId])
  @@index([eventDate])
  @@map("cash_events")
}

model ManualAdjustment {
  id                     String           @id @default(cuid())
  createdAt              DateTime         @default(now()) @map("created_at")
  createdBy              String           @map("created_by")
  symbol                 String
  effectiveDate          DateTime         @map("effective_date")
  adjustmentType         AdjustmentType   @map("adjustment_type")
  payloadJson            Json             @map("payload_json")
  reason                 String
  evidenceRef            String?          @map("evidence_ref")
  status                 AdjustmentStatus @default(ACTIVE)
  reversedByAdjustmentId String?          @map("reversed_by_adjustment_id")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  reversedBy ManualAdjustment?  @relation("ReversalChain", fields: [reversedByAdjustmentId], references: [id], onDelete: SetNull)
  reversals  ManualAdjustment[] @relation("ReversalChain")

  @@index([accountId, symbol, effectiveDate])
  @@index([status, effectiveDate])
  @@map("manual_adjustments")
}

/// Daily OHLC for one instrument (equity symbol or option contract).
/// instrumentKey is the canonical key defined in 00-overview §7.
model HistoricalMark {
  id            String         @id @default(cuid())
  instrumentKey String         @map("instrument_key")
  assetClass    MarkAssetClass @map("asset_class")
  /// Equity: symbol. Option: underlying symbol. Useful for filtering/backfill.
  symbol        String
  markDate      DateTime       @map("mark_date") @db.Date
  open          Decimal        @db.Decimal(20, 6)
  high          Decimal        @db.Decimal(20, 6)
  low           Decimal        @db.Decimal(20, 6)
  close         Decimal        @db.Decimal(20, 6)
  volume        Decimal?       @db.Decimal(28, 6)
  source        MarkSource     @default(MASSIVE_S3)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@unique([instrumentKey, markDate])
  @@index([symbol, markDate])
  @@index([markDate])
  @@map("historical_marks")
}

/// Materialized daily account value, split by asset class. One row per account/date.
/// This is what GET /api/analysis/account-value-series reads.
model AccountValueSnapshot {
  id                    String              @id @default(cuid())
  snapshotDate          DateTime            @map("snapshot_date") @db.Date
  cashValue             Decimal             @map("cash_value") @db.Decimal(20, 6)
  equityValue           Decimal             @map("equity_value") @db.Decimal(20, 6)
  optionValue           Decimal             @map("option_value") @db.Decimal(20, 6)
  totalValue            Decimal             @map("total_value") @db.Decimal(20, 6)
  /// Broker-reported NLV for this date if available (for reconciliation only).
  brokerNlv             Decimal?            @map("broker_nlv") @db.Decimal(20, 6)
  /// brokerNlv - totalValue when both present; null otherwise.
  reconcileDelta        Decimal?            @map("reconcile_delta") @db.Decimal(20, 6)
  /// Count of held instruments with no mark on this date (data-quality signal).
  unpricedPositionCount Int                 @default(0) @map("unpriced_position_count")
  source                ValueSnapshotSource @default(RECONSTRUCTED)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, snapshotDate])
  @@index([snapshotDate])
  @@map("account_value_snapshots")
}

/// Short-lived ownership record preventing overlapping scheduled pipeline runs.
/// Durable run history belongs to follow-up issue #310, not this lease table.
model ScheduledJobLease {
  jobName        String   @id @map("job_name")
  leaseOwner     String   @map("lease_owner")
  leaseExpiresAt DateTime @map("lease_expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([leaseExpiresAt])
  @@map("scheduled_job_leases")
}

/// Per matched-lot maximum favorable / adverse excursion. Populated by story 08.
model LotExcursion {
  id           String    @id @default(cuid())
  /// $ best unrealized gain during the holding window (>= 0 expected, but store raw).
  mfe          Decimal   @db.Decimal(20, 6)
  /// $ worst unrealized loss during the holding window (<= 0 expected, but store raw).
  mae          Decimal   @db.Decimal(20, 6)
  /// As a fraction of cost basis (e.g. 0.25 = +25%). Null if cost basis is 0.
  mfePct       Decimal?  @map("mfe_pct") @db.Decimal(12, 6)
  maePct       Decimal?  @map("mae_pct") @db.Decimal(12, 6)
  mfeDate      DateTime? @map("mfe_date") @db.Date
  maeDate      DateTime? @map("mae_date") @db.Date
  /// Number of trading days in the window that had a usable mark.
  pricedDays   Int       @default(0) @map("priced_days")
  /// Number of trading days in the window with NO mark (data-quality signal).
  unpricedDays Int       @default(0) @map("unpriced_days")
  computedAt   DateTime  @default(now()) @map("computed_at")

  matchedLotId String     @unique @map("matched_lot_id")
  matchedLot   MatchedLot @relation(fields: [matchedLotId], references: [id], onDelete: Cascade)

  @@map("lot_excursions")
}
